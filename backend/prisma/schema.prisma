datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String?
  isEmailVerified    Boolean            @default(false)
  googleId           String?            @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  profile            Profile?
  refreshTokens      RefreshToken[]
  resumes            Resume[]
  dsaProgress        DsaProgress[]
  interviewSessions  InterviewSession[]
  roadmaps           Roadmap[]
  notifications      Notification[]
  aiChatSessions     AiChatSession[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  avatarUrl     String?
  targetCompany String?
  targetRole    String?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("profiles")
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl    String
  atsScore   Int?
  parsedData String?
  analysis   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("resumes")
}

model DsaProgress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemTitle  String
  platform      String
  topic         String
  difficulty    String
  timeTaken     Int
  wrongAttempts Int
  confidence    Int
  notes         String?
  solvedAt      DateTime @default(now())

  @@index([userId])
  @@map("dsa_progress")
}

model InterviewSession {
  id               String             @id @default(uuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String
  status           String
  score            Int?
  feedback         String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  messages         InterviewMessage[]

  @@index([userId])
  @@map("interview_sessions")
}

model InterviewMessage {
  id        String           @id @default(uuid())
  sessionId String
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String
  content   String
  createdAt DateTime         @default(now())

  @@index([sessionId])
  @@map("interview_messages")
}

model Roadmap {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  targetCompany String
  steps         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("roadmaps")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  type      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]

  @@index([userId])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id        String        @id @default(uuid())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String
  content   String
  createdAt DateTime      @default(now())

  @@index([sessionId])
  @@map("ai_chat_messages")
}
