# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/ai_placement_db?schema=public"

# Redis Connection
REDIS_URL="redis://localhost:6379"

# Qdrant Vector DB Connection
QDRANT_URL="http://localhost:6333"

# JWT Secrets (Will be fully implemented in Milestone 2, configured here for compatibility)
JWT_ACCESS_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
